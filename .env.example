# Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
# Server ID for instant slash-command updates (Discord â†’ right-click server â†’ Copy Server ID with Developer Mode on). If empty, commands register globally (~1h delay).
DISCORD_GUILD_ID=

# Bot joins voice self-deafened (does not receive voice audio). Set to 0 to hear the channel like a normal user.
# BOT_VOICE_SELF_DEAF=1

# Per-guild rate limits (spam / Lavalink protection). Each guild has its own bucket so many servers can play at once.
# Light: skip, pause, resume, stop, player buttons (not Queue). Heavy: /play, /playlist add|play, track pick menus.
# Set to 0 to disable that tier.
# BOT_GUILD_COOLDOWN_LIGHT_MS=700
# BOT_GUILD_COOLDOWN_HEAVY_MS=2500

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/music-bot

# Lavalink (must match services/lavalink/application.yml server.password)
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# Admin Discord user IDs (comma-separated)
ADMIN_IDS=

# API
API_PORT=3001
# Use WEB_ORIGIN + /auth/... so OAuth completes on the same host as Next (see apps/web/next.config.mjs rewrites).
# Must match WEB_ORIGIN host/port so the browser finishes OAuth on the Next app (rewrites proxy /auth to API).
# Register this exact URL in Discord â†’ OAuth2 â†’ Redirects.
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
WEB_ORIGIN=http://localhost:3000
# Optional: override API host for Next rewrites (defaults to NEXT_PUBLIC_API_URL or 127.0.0.1:3001)
# API_INTERNAL_URL=http://127.0.0.1:3001
# Next dev port (if 3000 is in use, set e.g. 3100 and set WEB_ORIGIN to match)
WEB_PORT=3000
# Set to 1 to skip deleting apps/web/.next on each `npm run dev` (faster restarts; risk stale cache / 500 on /_next/static)
# NEXT_DEV_NO_CLEAN=1
# Set to 1 to disable Turbopack and use webpack for `next dev` (default is --turbo for stable dev on Windows)
# NEXT_DEV_NO_TURBO=1
# Long random string (required in production)
SESSION_SECRET=replace-with-random-32plus-chars
# Optional: bot posts analytics with header X-Internal-Key
BOT_INTERNAL_KEY=

# Web: API base for server-side / non-proxied use. Browser code should call same-origin /auth and /data/playlists (rewrites).
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional: override for web only. If unset, /add-bot uses CLIENT_ID from root .env (see next.config.mjs).
# NEXT_PUBLIC_DISCORD_CLIENT_ID=
# Optional permission bitfield for the invite button (default 36785152 if unset in code)
# NEXT_PUBLIC_DISCORD_BOT_PERMISSIONS=36785152

