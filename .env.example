# Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
# DISCORD_GUILD_ID=

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/music-bot

# Lavalink (must match services/lavalink/application.yml server.password)
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# Admin Discord user IDs (comma-separated)
ADMIN_IDS=

# API
API_PORT=3001
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback
WEB_ORIGIN=http://localhost:3100
WEB_PORT=3100
# Long random string (required in production)
SESSION_SECRET=replace-with-random-32plus-chars
# Optional: bot posts analytics with header X-Internal-Key
BOT_INTERNAL_KEY=

# Web (browser-visible API base)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# Super Admin
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Bot voice self deaf
BOT_VOICE_SELF_DEAF=1

# Bot voice idle leave ms
BOT_VOICE_IDLE_MS=120000
