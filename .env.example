# Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
# DISCORD_GUILD_ID=
# Optional: register slash commands on ClientReady (only if you run `node index.js` without `npm run dev`; npm run dev registers before start)
# BOT_REGISTER_ON_READY=1

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/music-bot

# Lavalink — must match services/lavalink/application.yml (lavalink.server.password, port, bind address).
# Do not wrap values in extra quotes; if playback fails while the bot shows "WebSocket ready", the issue is usually YouTube/Lavalink plugins, not these three lines.
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# Admin Discord user IDs (comma-separated)
ADMIN_IDS=

# API
API_PORT=3001
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback
WEB_ORIGIN=http://localhost:3100
WEB_PORT=3100
# Long random string (required in production)
SESSION_SECRET=replace-with-random-32plus-chars
# Optional: bot posts analytics with header X-Internal-Key
BOT_INTERNAL_KEY=

# Web (browser-visible API base)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# Super Admin
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Bot voice self deaf
BOT_VOICE_SELF_DEAF=1

# Bot voice idle leave ms
BOT_VOICE_IDLE_MS=120000
# Verbose /play trace logs in bot terminal ([play], [voice], [play:pick], [play:end]). Set to 0 to disable.
# BOT_PLAY_TRACE=0
# Log interaction age (ms) at handler entry — use when debugging Unknown interaction / 10062.
# BOT_INTERACTION_DEBUG=1
# Optional: per-guild cooldown between music commands (ms). Raise if you see "using music commands too quickly".
# BOT_GUILD_COOLDOWN_LIGHT_MS=700
# BOT_GUILD_COOLDOWN_HEAVY_MS=2500
