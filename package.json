{
  "name": "music-bot-system",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "pnpm --filter @djramu/api dev",
    "dev:bot": "pnpm --filter @djramu/bot dev",
    "dev:web": "pnpm --filter @djramu/web dev",
    "build": "pnpm --filter @djramu/web run build",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
